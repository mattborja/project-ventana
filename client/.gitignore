# Node.js dependencies installed by the onboarding script
onboarding/workspace/.vscode/mcp/node_modules/
onboarding/workspace/.vscode/mcp/npm-debug.log*
onboarding/workspace/.vscode/mcp/.npm/

# Environment / secret overrides — never commit real credentials
onboarding/workspace/.env
onboarding/workspace/.env.local

# Generated by npm install during onboarding
onboarding/workspace/.vscode/mcp/package-lock.json

# Python artifacts from server.py
onboarding/workspace/.vscode/mcp/__pycache__/
onboarding/workspace/.vscode/mcp/*.py[cod]
onboarding/workspace/.venv/
onboarding/workspace/venv/
