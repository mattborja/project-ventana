{
  "servers": {
    "ventana-kb": {
      "type": "stdio",
      "command": "node",
      "args": ["${workspaceFolder}/.vscode/mcp/server.js"],
      "env": {
        "GIT_REMOTE_URL": "<GIT_REMOTE_URL>"
      }
    },
    "ventana-kb-py": {
      "type": "stdio",
      "command": "python3",
      "args": ["${workspaceFolder}/.vscode/mcp/server.py"],
      "env": {
        "GIT_REMOTE_URL": "<GIT_REMOTE_URL>"
      }
    }
  }
}
